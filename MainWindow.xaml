<Window x:Class="LiveryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:LiveryManager.ViewModels"
        xmlns:converters="clr-namespace:LiveryManager.Converters"
        mc:Ignorable="d"
        Title="PMDG Livery Manager"
        Height="600" Width="900"
        MinHeight="420" MinWidth="640"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDrop="Window_PreviewDrop">

    <Window.Resources>
        <converters:StoreTypeConverter x:Key="StoreTypeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Loading bar -->
            <RowDefinition Height="4"/>
            <!-- Livery list -->
            <RowDefinition Height="*"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Toolbar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Store type selector -->
                <Label Content="Store type:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="150"
                          Margin="0,0,24,0"
                          VerticalAlignment="Center"
                          ItemsSource="{x:Static viewmodels:MainViewModel.StoreTypes}"
                          SelectedItem="{Binding SelectedStoreType, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource StoreTypeConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Aircraft selector -->
                <Label Content="Aircraft:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="220"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding AircraftPackages}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedAircraft, Mode=TwoWay}"/>

                <Label Content="Search:" VerticalAlignment="Center" Margin="24,0,4,0"/>
                <TextBox Width="220"
                         VerticalAlignment="Center"
                         Text="{Binding SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            </WrapPanel>
        </Border>

        <!-- ── Row 1: Indeterminate progress bar ─────────────────────────── -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- ── Row 2: Livery list ─────────────────────────────────────────── -->
        <Grid Grid.Row="2">

            <!-- Livery ListView -->
            <ListView x:Name="LvLiveries"
                      ItemsSource="{Binding Liveries}"
                      SelectedItem="{Binding SelectedLivery, Mode=TwoWay}"
                      SelectionMode="Single"
                      BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Preview" Width="96">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="72"
                                            Height="40"
                                            CornerRadius="2"
                                            Background="#F3F3F3"
                                            BorderBrush="#D7D7D7"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True">
                                        <Grid ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailPath}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>

                                            <TextBlock Text="No Preview"
                                                       FontSize="10"
                                                       Foreground="#7A7A7A"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Folder Name"
                                        DisplayMemberBinding="{Binding FolderName}"
                                        Width="320"/>
                        <GridViewColumn Header="ATC ID"
                                        DisplayMemberBinding="{Binding AtcId}"
                                        Width="160"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Empty state overlay -->
            <TextBlock Text="{Binding EmptyStateMessage}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#999999"
                       FontSize="14"
                       Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVis}}"/>

        </Grid>

        <!-- ── Row 3: Action buttons ──────────────────────────────────────── -->
        <Border Grid.Row="3"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">

                <Button Content="Install ZIPs..."
                        Command="{Binding InstallLiveryCommand}"
                        MinWidth="120" Height="28"
                        Margin="0,0,10,0"/>

                <Button Content="Uninstall"
                        Command="{Binding UninstallLiveryCommand}"
                        MinWidth="100" Height="28"/>

                <TextBlock Text="Tip: drag one or more .zip files onto the window to install them."
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#666666"/>

            </StackPanel>
        </Border>

        <!-- ── Row 4: Status bar ──────────────────────────────────────────── -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
